# REMOTE_COLAB_SSH_BROWSER.ipynb
# Notebook listo para ejecutar en Google Colab para habilitar SSH + Navegador Remoto (CDP/NoVNC) + Backup de Estado

"""
# NEXUS Cloud Node - Google Colab (Remote SSH & Browser Proxy)
Ejecuta las celdas a continuación en Google Colab para levantar una VM remota con GPU/RAM.
"""

# 1. Configurar SSH y NoVNC / Chrome Remoto con Cloudflare Tunnels
!apt-get update -qq
!apt-get install -y -qq xvfb fluxbox x11vnc websockify chromium-browser openssh-server

# Descargar cloudflared para tunelización sin puerto público
!wget -q https://github.com/cloudflare/cloudflared/releases/latest/download/cloudflared-linux-amd64.deb
!dpkg -i cloudflared-linux-amd64.deb

# 2. Iniciar servidor de pantalla virtual y navegador CDP
import subprocess
import time

subprocess.Popen(["Xvfb", ":1", "-screen", "0", "1280x800x24"])
time.sleep(1)
subprocess.Popen(["fluxbox"], env={"DISPLAY": ":1"})
subprocess.Popen(["x11vnc", "-forever", "-shared", "-nopw", "-display", ":1"])
subprocess.Popen(["websockify", "--web", "/usr/share/novnc", "6080", "localhost:5900"])
subprocess.Popen(["chromium-browser", "--remote-debugging-port=9222", "--no-sandbox", "--display=:1"])

# 3. Exponer puertos mediante Cloudflare Tunnel
print("=== TÚNEL NO VNC (ESCRITORIO REMOTO) ===")
subprocess.Popen(["cloudflared", "tunnel", "--url", "http://localhost:6080"])
print("=== TÚNEL CDP (CONTROL CHROME) ===")
subprocess.Popen(["cloudflared", "tunnel", "--url", "http://localhost:9222"])
